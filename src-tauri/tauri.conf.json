{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2-schema/main/schema.json",
  "productName": "Merge Pilot",
  "version": "0.1.0",
  "identifier": "com.mergepilot",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "Merge Pilot - Code Merge Tool",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "mergepilot.entitlements",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": "",
      "signingIdentity": null
    }
  }
}
