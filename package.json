{
  "name": "mergepilot",
  "version": "0.3.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "oxlint src/ .github/checks/ --report-unused-disable-directives",
    "check:frontend-standards": "node .github/checks/frontend-standards.mjs",
    "lint:fix": "oxlint src/ .github/checks/ --fix --report-unused-disable-directives",
    "format": "oxfmt --check src/ .github/checks/ package.json .oxlintrc.json .oxfmtrc.json",
    "format:fix": "oxfmt src/ .github/checks/ package.json .oxlintrc.json .oxfmtrc.json",
    "prepare": "husky",
    "test": "vitest run",
    "check:frontend": "npm run check:version && npm run lint && npm run format && npm run check:frontend-standards",
    "check:version": "node .github/checks/version-consistency.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "diff2html": "^3.4.48",
    "highlight.js": "^11.10.0",
    "marked": "^15.0.4",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.0",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.11",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.2.0"
  }
}
